        "nodes": [
          {
            "id": "string",
            "label": "string",
            "category": "system|service|database|external"
          }
        ],
        "edges": [
          {
            "source": "string",
            "target": "string",
            "label": "string"
          }
        ],
        "notes": [
          "string"
        ]
      },
      "export_renderer": "svg",
      "prompt_instructions": "Create a clean architecture diagram spec with 4-9 nodes and meaningful edges."
    },
    {
      "id": "diagram_process_flow",
      "name": "Process Flow Diagram",
      "artifact_type": "diagram",
      "domain": "generic",
      "intent": "process_flow",
      "audience": "Business Stakeholders",
      "description": "Structured process flow diagram.",
      "required_sections": [
        "title",
        "objective",
        "nodes",
        "edges",
        "notes"
      ],
      "forbidden_sections": [
